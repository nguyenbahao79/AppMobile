# Để trống khi chạy App cùng Wi-Fi với máy đang chạy Docker FE/BE.
# App sẽ tự gọi: http://<IP-máy>:3000/api/v1
#
# Chỉ bật dòng dưới nếu muốn ép App gọi một API URL cụ thể.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3000/api/v1

# Nếu Docker FE không chạy ở port 3000 thì đổi port tại đây.
EXPO_PUBLIC_DOCKER_FRONTEND_PORT=3000
